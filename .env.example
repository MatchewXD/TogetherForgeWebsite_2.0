# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe Support checkout (pick one approach)
#
# 1) Server-side Checkout Sessions (recommended for custom amounts + subscriptions)
#    Point this at a Supabase Edge Function or your API that creates a session
#    and returns { "url": "https://checkout.stripe.com/..." }
VITE_STRIPE_CHECKOUT_API_URL=

# 2) Pre-made Stripe Payment Links (JSON object)
#    Keys: {tierId}_{once|month} e.g. supporter_once, member_month, builder_once, custom_once
# VITE_STRIPE_PAYMENT_LINKS={"supporter_once":"https://buy.stripe.com/xxx","member_once":"https://buy.stripe.com/yyy","builder_once":"https://buy.stripe.com/zzz","supporter_month":"https://buy.stripe.com/aaa","member_month":"https://buy.stripe.com/bbb","builder_month":"https://buy.stripe.com/ccc","custom_once":"https://buy.stripe.com/ddd"}
