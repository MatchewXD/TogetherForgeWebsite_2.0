# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe Support checkout (pick one approach). Never put sk_ secret keys here.
#
# 1) Server-side Checkout Sessions (recommended)
#    Deploy: supabase/functions/create-checkout
#    Webhook: supabase/functions/stripe-webhook + supabase_donations_stripe.sql
VITE_STRIPE_CHECKOUT_API_URL=

# 2) Pre-made Stripe Payment Links (JSON object)
#    Keys: {tierId}_{once|month} e.g. supporter_once, member_month, custom_once
#    Optional fund prefix: runway_once, studio_supporter_once
# VITE_STRIPE_PAYMENT_LINKS={"supporter_once":"https://buy.stripe.com/xxx","member_once":"https://buy.stripe.com/yyy","builder_once":"https://buy.stripe.com/zzz","supporter_month":"https://buy.stripe.com/aaa","member_month":"https://buy.stripe.com/bbb","builder_month":"https://buy.stripe.com/ccc","custom_once":"https://buy.stripe.com/ddd","runway_once":"https://buy.stripe.com/eee"}
