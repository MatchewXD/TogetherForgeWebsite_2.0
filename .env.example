# Supabase (local example: http://127.0.0.1:54321)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Stripe (client) ───────────────────────────────────────────────────────
# ONLY publishable key may use VITE_ (pk_test_...). NEVER sk_test / sk_live here.
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional product id for Checkout line items (also set STRIPE_PRODUCT_ID on the function)
VITE_STRIPE_PRODUCT_ID=prod_UvB5nILGYFdPln

# Optional explicit checkout function URL. If empty, client uses:
#   {VITE_SUPABASE_URL}/functions/v1/create-checkout
# VITE_STRIPE_CHECKOUT_API_URL=http://127.0.0.1:54321/functions/v1/create-checkout

# Optional Payment Links fallback (JSON). Keys: supporter_once, custom_once, runway_once, ...
# VITE_STRIPE_PAYMENT_LINKS={}

# ─── Stripe (server / Edge Function only — put in supabase/.env, NOT here) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRODUCT_ID=prod_UvB5nILGYFdPln
# STRIPE_WEBHOOK_SECRET=whsec_...
